# Environment
ENVIRONMENT=development

# Application
APP_NAME=AI Live Doubt Manager
APP_VERSION=1.0.0
DEBUG=false

# Database
POSTGRES_USER=your-db-user
POSTGRES_PASSWORD=your-strong-db-password
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/ai_doubt_manager
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE=3600
DATABASE_POOL_PRE_PING=true

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_DECODE_RESPONSES=true

# Security
SECRET_KEY=change-me-in-production-use-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_BCRYPT_ROUNDS=12

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# YouTube API
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/youtube/auth/callback

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Quota Limits
DEFAULT_DAILY_ANSWER_LIMIT=100
DEFAULT_MONTHLY_SESSION_LIMIT=30

# Queue Names
QUEUE_COMMENT_INGEST=comment_ingest
QUEUE_CLASSIFICATION=classification
QUEUE_EMBEDDING=embedding
QUEUE_CLUSTERING=clustering
QUEUE_ANSWER_GENERATION=answer_generation

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# Observability
ENABLE_METRICS=true
METRICS_PORT=9090

# WebSocket
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_TIMEOUT=300

# Workers
WORKERS=classification,embeddings,clustering,answer_generation,trigger_monitor

GEMINI_API_KEY=your-gemini-api-key