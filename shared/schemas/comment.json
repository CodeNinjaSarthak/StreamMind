{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Comment",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "youtube_comment_id": {
      "type": "string"
    },
    "author_name": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "is_question": {
      "type": "boolean"
    },
    "is_answered": {
      "type": "boolean"
    },
    "session_id": {
      "type": "integer"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["youtube_comment_id", "author_name", "text", "session_id"]
}

