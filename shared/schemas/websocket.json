{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WebSocket Message",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["comment", "cluster", "answer", "status"]
    },
    "data": {
      "type": "object"
    },
    "timestamp": {
      "type": "number"
    }
  },
  "required": ["type", "data"]
}

