{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Answer",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "cluster_id": {
      "type": "integer"
    },
    "comment_id": {
      "type": "integer"
    },
    "text": {
      "type": "string"
    },
    "is_posted": {
      "type": "boolean"
    },
    "posted_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["cluster_id", "text"]
}

