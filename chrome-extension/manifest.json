{
  "manifest_version": 3,
  "name": "AI Live Doubt Manager",
  "version": "1.0.0",
  "description": "Manage live doubt sessions with YouTube integration",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "identity",
    "scripting"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "dashboard/background.html",
    "default_title": "AI Live Doubt Manager"
  },
  "web_accessible_resources": [
    {
      "resources": ["oauth.html"],
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*"]
    }
  ]
}

